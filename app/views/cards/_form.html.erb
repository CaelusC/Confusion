<%= form_with model: [@project || @card_project, @card] do |form| %>
    <% if @card.errors.any? %>
        <% @card.errors.full_messages.each do |message| %>
            <p><%= message %></p>
        <% end %>
    <% end %>

    <%= form.text_field :title, placeholder: "Card Title" %>
    <%= form.text_area :description, placeholder: "Description", rows: 4 %>

    <%= form.select :priority, ["low", "medium", "high", "critical"], include_blank: "Select Priority" %>
    <%= form.select :card_type, [["Card", "card"], ["Bug", "bug"]], include_blank: "Select Type" %>
    <%= form.select :status, ["todo", "in_progress", "done"], include_blank: "Select Status" %>
    <%= form.select :sprint_id, @sprints.map { |sprint| [sprint.name, sprint.id] }, include_blank: "Unassigned" %>

    <% if @tags.any? %>
        <div>
            <h3>Tags</h3>
            <% @tags.each do |tag| %>
                <label>
                    <%= check_box_tag "card[tag_ids][]", tag.id, @card.tag_ids.include?(tag.id) %>
                    <%= tag.name %>
                </label>
            <% end %>
        </div>
    <% end %>

    <%= form.submit %>
<% end %>
